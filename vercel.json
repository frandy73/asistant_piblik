{
  "version": 2,
  "routes": [
    {
      "src": "/api/ai/chat",
      "dest": "/api/ai/chat"
    },
    {
      "src": "/api/chatpdf/(.*)",
      "dest": "/server.ts"
    },
    {
      "src": "/(.*).(js|css|json|png|jpg|svg|webmanifest|ico)",
      "dest": "/$1.$2",
      "check": true
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
