{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "server.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/ai/chat",
      "dest": "api/ai/chat.ts"
    },
    {
      "src": "/api/(.*)",
      "dest": "server.ts"
    },
    {
      "src": "/(.*).(js|css|json|png|jpg|svg|webmanifest|ico)",
      "dest": "/$1.$2",
      "check": true
    },
    {
      "src": "/(.*)",
      "dest": "index.html"
    }
  ]
}
